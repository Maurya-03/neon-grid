rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Rooms: Read by anyone, create/update with validation, delete restricted
    match /rooms/{roomId} {
      // Anyone can read rooms
      allow read: if true;

      // Allow creating rooms with proper structure (anonymous users allowed)
      allow create: if
        resource == null &&
        request.resource.data.keys().hasAll(['name', 'description', 'createdBy', 'createdAt']) &&
        request.resource.data.name is string &&
        request.resource.data.description is string &&
        request.resource.data.createdBy is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.description.size() > 0;

      // Allow updates for room stats and locking (anonymous users allowed for basic updates)
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activeUsers', 'locked', 'lastActivity']);

      // Allow deletion for admin operations (client-side validation)
      allow delete: if true;

      // Messages subcollection
      match /messages/{messageId} {
        // Anyone can read messages
        allow read: if true;

        // Allow creating messages with proper structure (anonymous users allowed)
        // Messages must have either text OR mediaUrl (or both)
        allow create: if
          resource == null &&
          request.resource.data.keys().hasAll(['sender', 'timestamp']) &&
          request.resource.data.sender is string &&
          request.resource.data.sender.size() > 0 &&
          (
            // Must have text OR mediaUrl (or both)
            (request.resource.data.text is string && request.resource.data.text.size() > 0) ||
            (request.resource.data.mediaUrl is string && request.resource.data.mediaUrl.size() > 0)
          );

        // Allow updates for admin moderation (flagging/deleting) - client-side validation
        allow update: if
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['flagged', 'deleted']);

        // Allow deletion for admin operations - client-side validation
        allow delete: if true;
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}